# Maintainer: Amurru Zerouk <contact@amurru.dev>
# https://github.com/amurru/gocaster

_pkgname=gocaster
pkgname=${_pkgname}-git
pkgver=0.0.0.r24.g9df222a
pkgrel=1
pkgdesc="A terminal podcast client written in Go"
arch=('x86_64' 'aarch64')
url="https://github.com/amurru/gocaster"
license=('MIT')
depends=('mpv' 'sqlite')
makedepends=('git' 'go')
provides=("${_pkgname}")
conflicts=("${_pkgname}")
source=("git+${url}.git")
sha256sums=('SKIP')

pkgver() {
	cd "${srcdir}/${_pkgname}" || return 1
	printf "0.0.0.r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
	cd "${srcdir}/${_pkgname}" || return 1
	export CGO_ENABLED=1
	go build -trimpath -buildmode=pie -mod=readonly -modcacherw -o "${_pkgname}" ./cmd/gocaster
}

package() {
	cd "${srcdir}/${_pkgname}" || return 1
	install -Dm755 "${_pkgname}" "${pkgdir}/usr/bin/${_pkgname}"
	install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
	install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
